# Supabase (obligatoire pour le frontend)
# Créez une copie de ce fichier en .env et renseignez les valeurs.
# Ne commitez jamais le fichier .env.
#
# Trouvez vos clés ici :
# Dashboard Supabase → Settings → API → Project API keys
#
# IMPORTANT : la clé anon est un JWT qui commence par "eyJ..."
# Ne confondez pas avec la clé "service_role" qui est secrète.

VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.votre_cle_ici
